{
  "name": "micahl-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scheduler": "node src/scheduler/index.js",
    "build:scheduler": "tsc --project tsconfig.json --outDir dist",
    "setup:airtable": "npx ts-node --project tsconfig.scripts.json scripts/setup-airtable.ts",
    "seed:airtable": "npx ts-node --project tsconfig.scripts.json scripts/seed-airtable.ts",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^server-only$": "<rootDir>/src/lib/airtable/__mocks__/server-only.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "moduleResolution": "node",
          "esModuleInterop": true
        }
      }]
    },
    "testPathPatterns": ["src/**/__tests__/**/*.test.ts"]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "airtable": "^0.12.2",
    "bree": "^9.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bree": "^7.1.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
